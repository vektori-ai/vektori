POSTGRES_PASSWORD=changeme
ADMIN_KEY=change-this-too

# --- LLM for fact extraction ---
# Option A: Gemini (recommended, free tier available)
GEMINI_API_KEY=
EXTRACTION_MODEL=gemini:gemini-2.5-flash-lite

# Option B: Groq (also free tier)
# GROQ_API_KEY=
# EXTRACTION_MODEL=litellm:groq/llama-3.3-70b-versatile

# --- Embeddings ---
# Option A: Local sentence-transformers (no API key, downloads model on first run ~90MB)
EMBEDDING_MODEL=sentence-transformers:all-MiniLM-L6-v2
EMBEDDING_DIM=384

# Option B: Local BGE (better quality, 768-dim, ~400MB)
# EMBEDDING_MODEL=bge:BAAI/bge-base-en-v1.5
# EMBEDDING_DIM=768
